generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================
// FASE 1: Seguridad y Base
// =======================
model User {
  id        String     @id @default(uuid())
  email     String     @unique
  role      String     @default("PENDIENTE") // ADMIN, GERENTE, TECNICO, PENDIENTE
  logs      AuditLog[]
  assignedProjects Project[] @relation("ProjectTeam")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // EJ: "CREATE_VERSION", "UPDATE_INVENTORY"
  entity    String   // EJ: "Document", "Inventory"
  details   String?  // JSON con cambios
  createdAt DateTime @default(now())
}

// =======================
// FASE 3: CRM y Proyectos
// =======================
model Client {
  id       String    @id @default(uuid())
  name     String
  contact  String?
  email    String?
  phone    String?
  rfc      String?
  address  String?
  projects Project[]
}

model Project {
  id          String        @id @default(uuid())
  name        String
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  progress    Int           @default(0) // Auto-calculado como promedio de las tareas
  status      String        @default("NORMAL") // NORMAL, RIESGO, ATORADO
  blockReason String?       // Causa del "Atorado" para el Visor
  budget      Float         @default(0) // Presupuesto asignado al proyecto
  team        User[]        @relation("ProjectTeam") // Usuarios asignados al proyecto
  documents   Document[]
  inventory   Inventory[]
  departments ProjectDepartment[]
  notes       ProjectNote[]

  @@index([clientId])
  @@index([status])
}

// =======================
// Departamentos del Proyecto
// =======================
model ProjectDepartment {
  id        String        @id @default(uuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String        // "Mecánico", "Eléctrico", "Fabricación", "Integración"
  progress  Int           @default(0) // 0-100
  status    String        @default("NORMAL")
  tasks     ProjectTask[]
  
  @@unique([projectId, name])
}

// =======================
// Plan de Trabajo (Tareas Dinámicas)
// =======================
model ProjectTask {
  id                  String            @id @default(uuid())
  projectDepartmentId String
  department          ProjectDepartment @relation(fields: [projectDepartmentId], references: [id], onDelete: Cascade)
  name                String
  startDate           DateTime?
  endDate             DateTime?
  progress            Int               @default(0) // 0-100
  status              String            @default("PENDIENTE") // PENDIENTE, EN_PROGRESO, COMPLETADA
  createdAt           DateTime          @default(now())

  @@index([projectDepartmentId])
  @@index([status])
}

// =======================
// Notas Rápidas
// =======================
model ProjectNote {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content   String
  author    String   
  createdAt DateTime @default(now())

  @@index([projectId])
}

// =======================
// FASE 4: Gestor Documental (DMS)
// =======================
model Document {
  id        String            @id @default(uuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String            // Ej: "Plano_Electrico_Principal"
  type      String            // PDF, MBM, IMG
  folder    String            @default("General")
  versions  DocumentVersion[]

  @@index([projectId])
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int      // 1, 2, 3...
  url        String   // Supabase Storage URL
  notes      String?  // Ej: "Ajuste de tubería"
  uploadedBy String   // userId
  createdAt  DateTime @default(now())

  // Prevents race condition: two uploads cannot create the same version number for the same document
  @@unique([documentId, version])
  @@index([documentId])
}

// =======================
// FASE 2: Almacén e Inventario
// =======================
model Product {
  id         String      @id @default(uuid())
  sku        String      @unique
  name       String
  category   String
  department String      @default("General")
  itemType   String      @default("Consumible")
  minStock   Int         @default(5)
  stock      Int         @default(0)
  cost       Float       @default(0) // Costo unitario para control financiero
  inventory        Inventory[]
  machineMaterials MachineMaterial[]

  @@index([category])
  @@index([department])
  @@index([itemType])
}

model Inventory {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict) // Prevent deleting products with history
  projectId String?  // Puede estar asignado a un proyecto
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)  // If project is deleted, keep the movement record but unlink it
  quantity  Int
  type      String   // ENTRADA, SALIDA
  date      DateTime @default(now())

  @@index([productId])
  @@index([projectId])
  @@index([type])
}

// =======================
// FASE 5: Gestión de Máquinas
// =======================
model Machine {
  id           String      @id @default(uuid())
  name         String
  serialNumber String      @unique
  status       String      @default("ACTIVA") // ACTIVA, MANTENIMIENTO, INACTIVA
  category     String      @default("Maquinaria") // Vehículo, Computación, Herramienta, etc.
  brand        String?
  model        String?
  imageUrl     String?
  
  materials    MachineMaterial[]
  documents    MachineDocument[]
  maintenances MaintenanceLog[]
}

model MachineMaterial {
  id        String   @id @default(uuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Restrict)
  name      String?  // Para componentes libres que no están en el almacén
  quantity  Int      @default(1)
  
  // Eliminamos el @@unique para permitir registrar varios componentes libres
}

model MachineDocument {
  id         String   @id @default(uuid())
  machineId  String
  machine    Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  name       String
  url        String
  type       String   // e.g. "MANUAL", "GARANTIA"
  uploadedAt DateTime @default(now())
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  machineId   String
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  type        String   // "PREVENTIVO", "CORRECTIVO"
  description String
  performedBy String
}
