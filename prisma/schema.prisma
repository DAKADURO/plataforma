generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================
// FASE 1: Seguridad y Base
// =======================
model User {
  id        String     @id @default(uuid())
  email     String     @unique
  role      String     @default("PENDIENTE") // ADMIN, GERENTE, TECNICO, PENDIENTE
  logs      AuditLog[]
  assignedProjects Project[] @relation("ProjectTeam")
  movements Inventory[]  // Movements this user made
  createdTags Tag[]      // Tags this user created
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // EJ: "CREATE_VERSION", "UPDATE_INVENTORY"
  entity    String   // EJ: "Document", "Inventory"
  details   String?  // JSON con cambios
  createdAt DateTime @default(now())
}

// =======================
// FASE 3: CRM y Proyectos
// =======================
model Client {
  id        String     @id @default(uuid())
  name      String
  contact   String?
  email     String?
  phone     String?
  rfc       String?
  address   String?
  projects  Project[]
  proposals Proposal[]
}

model Project {
  id          String        @id @default(uuid())
  name        String
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  progress    Int           @default(0) // Auto-calculado como promedio de las tareas
  status      String        @default("NORMAL") // NORMAL, RIESGO, ATORADO
  blockReason String?       // Causa del "Atorado" para el Visor
  budget      Float         @default(0) // Presupuesto asignado al proyecto
  team        User[]        @relation("ProjectTeam") // Usuarios asignados al proyecto
  documents   Document[]
  inventory   Inventory[]
  departments ProjectDepartment[]
  notes       ProjectNote[]

  @@index([clientId])
  @@index([status])
}

// =======================
// Departamentos del Proyecto
// =======================
model ProjectDepartment {
  id        String        @id @default(uuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String        // "Mecánico", "Eléctrico", "Fabricación", "Integración"
  progress  Int           @default(0) // 0-100
  status    String        @default("NORMAL")
  tasks     ProjectTask[]
  
  @@unique([projectId, name])
}

// =======================
// Plan de Trabajo (Tareas Dinámicas)
// =======================
model ProjectTask {
  id                  String            @id @default(uuid())
  projectDepartmentId String
  department          ProjectDepartment @relation(fields: [projectDepartmentId], references: [id], onDelete: Cascade)
  name                String
  startDate           DateTime?
  endDate             DateTime?
  progress            Int               @default(0) // 0-100
  status              String            @default("PENDIENTE") // PENDIENTE, EN_PROGRESO, COMPLETADA
  createdAt           DateTime          @default(now())

  @@index([projectDepartmentId])
  @@index([status])
}

// =======================
// Notas Rápidas
// =======================
model ProjectNote {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content   String
  author    String   
  createdAt DateTime @default(now())

  @@index([projectId])
}

// =======================
// FASE 4: Gestor Documental (DMS)
// =======================
model Document {
  id        String            @id @default(uuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String            // Ej: "Plano_Electrico_Principal"
  type      String            // PDF, MBM, IMG
  folder    String            @default("General")
  versions  DocumentVersion[]

  @@index([projectId])
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int      // 1, 2, 3...
  url        String   // Supabase Storage URL
  notes      String?  // Ej: "Ajuste de tubería"
  uploadedBy String   // userId
  createdAt  DateTime @default(now())

  // Prevents race condition: two uploads cannot create the same version number for the same document
  @@unique([documentId, version])
  @@index([documentId])
}

// =======================
// FASE 2: Almacén e Inventario
// =======================
model Product {
  id         String      @id @default(uuid())
  sku        String      @unique
  name       String
  category   String
  department String      @default("General")
  itemType   String      @default("Consumible")
  minStock   Int         @default(5)
  stock      Int         @default(0)
  cost       Float       @default(0) // Costo unitario para control financiero
  lastAlertedDate DateTime?
  isAlertEnabled Boolean @default(true)
  inventory        Inventory[]
  machineMaterials MachineMaterial[]
  alerts ReorderAlert[]
  tags ProductTag[]

  @@index([category])
  @@index([department])
  @@index([itemType])
}

model Inventory {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict) // Prevent deleting products with history
  projectId String?  // Puede estar asignado a un proyecto
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)  // If project is deleted, keep the movement record but unlink it
  userId    String?  // Who made the movement
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  quantity  Int
  type      String   // ENTRADA, SALIDA
  date      DateTime @default(now())
  notes     String?  // Optional reason/notes for the movement
  isManual  Boolean  @default(true)

  @@index([productId])
  @@index([userId])
  @@index([projectId])
  @@index([type])
  @@index([date])
  @@index([productId, date])
}

// =======================
// FASE 5: Gestión de Máquinas
// =======================
model Machine {
  id           String      @id @default(uuid())
  name         String
  serialNumber String      @unique
  status       String      @default("ACTIVA") // ACTIVA, MANTENIMIENTO, INACTIVA
  category     String      @default("Maquinaria") // Vehículo, Computación, Herramienta, etc.
  brand        String?
  model        String?
  imageUrl     String?
  isImported   Boolean     @default(false)

  materials    MachineMaterial[]
  documents    MachineDocument[]
  maintenances MaintenanceLog[]
}

model MachineMaterial {
  id        String   @id @default(uuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Restrict)
  name      String?  // Para componentes libres que no están en el almacén
  quantity  Int      @default(1)
  
  // Eliminamos el @@unique para permitir registrar varios componentes libres
}

model MachineDocument {
  id         String   @id @default(uuid())
  machineId  String
  machine    Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  name       String
  url        String
  type       String   // e.g. "MANUAL", "GARANTIA"
  uploadedAt DateTime @default(now())
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  machineId   String
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  type        String   // "PREVENTIVO", "CORRECTIVO"
  description String
  performedBy String
}

// =======================
// FASE 6: Propuestas
// =======================
model Proposal {
  id          String             @id @default(uuid())
  clientId    String
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  amount      Float              @default(0)
  status      String             @default("BORRADOR") // BORRADOR, ENVIADA, APROBADA, RECHAZADA, PROYECTO
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  photos      ProposalPhoto[]
  documents   ProposalDocument[]
  materials   ProposalMaterial[]

  @@index([clientId])
  @@index([status])
}

model ProposalPhoto {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  createdAt  DateTime @default(now())

  @@index([proposalId])
}

model ProposalDocument {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  name       String
  type       String   // PROPUESTA, ORDEN_COMPRA, REPORTE, PLANO, OTRO
  url        String
  createdAt  DateTime @default(now())

  @@index([proposalId])
}

model ProposalMaterial {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  name       String
  category   String   @default("General")
  quantity   Float    @default(1)
  unitPrice  Float    @default(0)

  @@index([proposalId])
}

// =======================
// Almacén: Alertas de Reposición
// =======================
model ReorderAlert {
  id String @id @default(uuid())
  productId String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  alertType String        // "LOW_STOCK", "OUT_OF_STOCK"
  severity String         // "WARNING", "CRITICAL"
  status String @default("ACTIVE") // "ACTIVE", "ACKNOWLEDGED", "RESOLVED"
  createdAt DateTime @default(now())
  resolvedAt DateTime?
  acknowledgedBy String?
  acknowledgedAt DateTime?

  @@index([productId])
  @@index([status])
}

// =======================
// Almacén: Etiquetas (Tags) de Productos
// =======================
model Tag {
  id String @id @default(uuid())
  name String @unique
  description String?
  color String?           // For badge styling (hex or CSS color)
  createdBy String
  createdByUser User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  products ProductTag[]
  createdAt DateTime @default(now())

  @@index([createdBy])
}

model ProductTag {
  id String @id @default(uuid())
  productId String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId String
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@index([productId])
  @@index([tagId])
}
